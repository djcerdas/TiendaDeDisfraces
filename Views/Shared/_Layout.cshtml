@using Microsoft.AspNetCore.Http

@{
    // Datos de sesión del usuario actual
    var usuario = Context.Session.GetString("Usuario");
    var rol = Context.Session.GetString("Rol");
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"] - TiendaDeDisfraces</title>
    <link rel="stylesheet" href="~/css/css.css" />
</head>
<body>
    <div id="container">

        <!-- Encabezado principal -->
        <div id="header">
            <div class="headtitle">Tienda de Disfraces</div>
        </div>

        <!-- Barra de menú principal -->
        <div id="menu">
            <ul>
                <!-- Menú izquierdo -->
                <li><a asp-controller="Home" asp-action="Index">Home</a></li>

                @if (rol == "Cajero" || rol == "ITAdmin" || rol == "Supervisor")
                {
                    <li><a asp-controller="Carrito" asp-action="Index">Carrito</a></li>
                }

                @if (rol == "ITAdmin" || rol == "Supervisor")
                {
                    <li><a asp-controller="Producto" asp-action="Index">Productos</a></li>
                    <li><a asp-controller="Usuario" asp-action="Index">Usuarios</a></li>
                }

                <!-- Menú derecho -->
                <li class="menu-right-item cart-item">
                    <a href="javascript:void(0);">
                        🛒 <span class="cart-count">0</span>
                    </a>
                </li>

                @if (string.IsNullOrEmpty(usuario))
                {
                    <li class="menu-right-item">
                        <a asp-controller="Usuario" asp-action="Login">Login</a>
                    </li>
                }
                else
                {
                    <li class="menu-right-item">
                        <a asp-controller="Usuario" asp-action="Logout">Logout</a>
                    </li>
                    <li class="menu-right-item">
                        <a href="javascript:void(0);">@usuario</a>
                    </li>
                }
            </ul>
        </div>

        <!-- Contenido dinámico -->
        <div id="content">
            @RenderBody()
        </div>

    </div>
    
    
    @* Scripts globales del sistema *@
    @RenderSection("Scripts", required: false)
</body>
</html>