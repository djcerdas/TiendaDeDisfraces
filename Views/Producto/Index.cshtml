@model IEnumerable<TiendaDeDisfraces.Models.Producto>

<p>
    @Html.ActionLink("Create New", "Create")
</p>

<table class="table">
    <tr>
        <th>Id</th>
        <th>Nombre</th>
        <th>Precio</th>
        <th>Tipo</th>
        <th>Público</th>
        <th>Talla</th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Nombre</td>
            <td>@item.Precio</td>

            <td>
                @(item.TipoProductoId == 1 ? "Disfraz" :
                  item.TipoProductoId == 2 ? "Accesorio" : "Maquillaje")
            </td>

            <td>
                @(item.TipoPublicoId == 1 ? "Adulto" :
                  item.TipoPublicoId == 2 ? "Niño" : "Todo Público")
            </td>

            <td>
                @(item.TipoProductoId == 1 ? item.Talla : "-")
            </td>

            <td>
                @Html.ActionLink("Actualizar", "Edit", new { id = item.Id }) |
                @Html.ActionLink("Eliminar", "Delete", new { id = item.Id })
            </td>
        </tr>
    }
</table>