@model TiendaDeDisfraces.Models.Usuario

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Configuración Inicial</title>
    <link rel="stylesheet" href="~/css/css.css" />
</head>

<body>

    <div id="container">

        <!-- Encabezado principal -->
        <div id="header">
            <div class="headtitle">Tienda de Disfraces</div>
        </div>

        <!-- Contenido principal -->
        <div id="content">
            <div id="insidecontent">

                <h1>Configuración Inicial</h1>

                <p>
                    Cree el usuario administrador del sistema.<br />
                    Complete todos los campos requeridos.
                </p>

                <!-- Muestra errores del modelo -->
                @Html.ValidationSummary()

                <!-- Formulario de creación del primer usuario -->
                <form asp-action="Index" method="post">
                    @Html.AntiForgeryToken()

                    <p>
                        <label>Nombre</label><br />
                        <input asp-for="Nombre" id="Nombre" />
                    </p>

                    <p>
                        <label>Cédula</label><br />
                        <input asp-for="Cedula" id="Cedula" />
                    </p>

                    <p>
                        <label>Teléfono</label><br />
                        <input asp-for="Telefono" id="Telefono" />
                    </p>

                    <p>
                        <label>Correo</label><br />
                        <input asp-for="Correo" />
                    </p>

                    <p>
                        <label>Usuario</label><br />
                        <input asp-for="Username" />
                    </p>

                    <p>
                        <label>Contraseña</label><br />
                        <input asp-for="Password" type="password" />
                    </p>

                    <p>
                        <button type="submit">Crear Administrador</button>
                    </p>

                </form>

            </div>
        </div>

    </div>

    <!-- =========================================
         VALIDACIÓN EN TIEMPO REAL (jQuery)
         - Se ejecuta en cada tecla (evento input)
         - Limpia datos inválidos automáticamente
         - Mejora la experiencia del usuario
         ========================================= -->
    <!-- Librería jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(document).ready(function () {

        // =========================================
        // NOMBRE → Solo letras y espacios
        // Elimina números y símbolos automáticamente
        // =========================================
        $("#Nombre").on("input", function () {
        let clean = $(this).val().replace(/[^a-zA-Z\s]/g, "");
        $(this).val(clean);
        });

        // =========================================
        // CÉDULA → Solo números
        // Elimina letras o caracteres inválidos
        // =========================================
        $("#Cedula").on("input", function () {
        let clean = $(this).val().replace(/\D/g, "");
        $(this).val(clean);
        });

        // =========================================
        // TELÉFONO → Solo números (máx 8 dígitos)
        // =========================================
        $("#Telefono").on("input", function () {
        let clean = $(this).val().replace(/\D/g, "").slice(0, 8);
        $(this).val(clean);
        });

        });
    </script>

</body>
</html>